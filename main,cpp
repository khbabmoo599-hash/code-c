#include <iostream>
#include "student.h"

using namespace std;

(int* a, int* b) {
    int temp = *a;
    *a = *b;
    *b = temp;
}

int main() {
    int choice;

{
        cout << "=== STUDENT MANAGEMENT SYSTEM ===\n";
        cout << "1. Add Student\n";
        cout << "2. Display All Students\n";
        cout << "3. Search Student by ID\n";
        cout << "4. Update Student\n";
        cout << "5. Delete Student\n";
        cout << "6. Exit Program\n";
        cout << "=================================\n";
        cout << "Enter your choice (1-6): ";
        cin >> choice;
        cout << "\n";

        // Call the appropriate function depending on choice
        switch (choice) {
            case 1:
                addStudent();
                break;
            case 2:
                displayStudents();
                break;
            case 3:
                searchStudent();
                break;
            case 4:
                updateStudent();
                break;
            case 5:
                deleteStudent();
                break;
            case 6:
                cout << "Exiting the program. Goodbye!\n";
                break;
            default:
                cout << "Invalid choice! Please enter a number between 1 and 6.\n\n";
        }
    } while (choice != 6); // End only when choice is 6

    return 0;
}
